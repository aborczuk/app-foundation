{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://app-foundation.local/contracts/orchestrator-step-result.schema.json",
  "title": "OrchestratorStepResult",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "ok",
    "exit_code",
    "correlation_id"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "ok": {
      "type": "boolean"
    },
    "exit_code": {
      "type": "integer",
      "enum": [
        0,
        1,
        2
      ]
    },
    "gate": {
      "type": [
        "string",
        "null"
      ]
    },
    "reasons": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "error_code": {
      "type": [
        "string",
        "null"
      ]
    },
    "next_phase": {
      "type": [
        "string",
        "null"
      ]
    },
    "debug_path": {
      "type": [
        "string",
        "null"
      ]
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "exit_code": {
            "const": 0
          }
        }
      },
      "then": {
        "required": [
          "next_phase"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "exit_code": {
            "const": 1
          }
        }
      },
      "then": {
        "required": [
          "gate",
          "reasons"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "exit_code": {
            "const": 2
          }
        }
      },
      "then": {
        "required": [
          "error_code",
          "debug_path"
        ]
      }
    }
  ]
}
