# ClickUp control-plane runtime environment template.
# Copy to your local .env file and replace placeholders before running.

CLICKUP_API_TOKEN=replace-with-clickup-api-token
CLICKUP_WEBHOOK_SECRET=replace-with-clickup-webhook-secret
N8N_DISPATCH_BASE_URL=http://localhost:5678/webhook
# For local n8n via docker-compose.n8n.yml use: http://localhost:5678/webhook
CONTROL_PLANE_ALLOWLIST={"space_ids":["space_123456"],"list_ids":["list_987654"]}
CONTROL_PLANE_DB_PATH=.speckit/control-plane.db
CONTROL_PLANE_REQUEST_TIMEOUT_SECONDS=10
CONTROL_PLANE_COMPLETION_TOKEN=replace-with-completion-callback-token

# HITL pause/resume settings (Phase 3)
CONTROL_PLANE_HITL_WAITING_STATUS=Waiting for Input
CONTROL_PLANE_HITL_BLOCKED_STATUS=Blocked
CONTROL_PLANE_HITL_TIMEOUT_SECONDS=86400
